{
  "kind": "collectionType",
  "collectionName": "page_contents",
  "info": {
    "singularName": "page-content",
    "pluralName": "page-contents",
    "displayName": "Page Content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "text.rich-text",
        "text.text-and-image",
        "image.carousel",
        "image.media",
        "content.card-container"
      ]
    },
    "blog": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::blog.blog",
      "mappedBy": "page_content"
    },
    "page": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page.page",
      "inversedBy": "page_content"
    }
  }
}
