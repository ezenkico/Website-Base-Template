{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "Image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "page_content": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page-content.page-content",
      "inversedBy": "blog"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "blogs"
    },
    "excerpt": {
      "type": "string"
    },
    "featured": {
      "type": "boolean"
    },
    "Seo": {
      "type": "component",
      "component": "page.seo",
      "repeatable": false
    }
  }
}
